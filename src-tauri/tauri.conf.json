{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chunky",
  "version": "0.1.0",
  "identifier": "com.chunky.desktop",
  "build": {
    "beforeBuildCommand": "pnpm --filter @chunky/ui-app build",
    "beforeDevCommand": "pnpm --filter @chunky/ui-app dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../src/ui-app/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Chunky",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "publisher": "NestedCube",
    "copyright": "Copyright © 2026 nestedcube.com",
    "category": "Productivity",
    "shortDescription": "Local knowledge graph for asset collections with MCP access.",
    "longDescription": "Chunky is a standalone knowledge-graph desktop app: organise files into projects and collections, extract text from PDFs / Office documents / images, and expose the whole graph to Claude via an embedded MCP server. All data stays local.",
    "resources": [
      "embedded/models/bge-small-en-v1.5/config.json",
      "embedded/models/bge-small-en-v1.5/tokenizer.json",
      "embedded/models/bge-small-en-v1.5/model.safetensors"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "macos/entitlements.plist",
      "signingIdentity": null,
      "providerShortName": null,
      "hardenedRuntime": true,
      "exceptionDomain": null
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "libappindicator-gtk3"
        ]
      }
    }
  }
}
